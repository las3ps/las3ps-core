generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("PENDING")
  createdAt DateTime @default(now())
}