generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id               String   @id @default(cuid())
  name             String
  email            String
  why              String
  financialStage   String
  structuredCommit Boolean
  status           String   @default("PENDING")
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
}